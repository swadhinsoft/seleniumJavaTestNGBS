<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Amazon.in BrowserStack Suite" verbose="1" parallel="tests" thread-count="5">

    <listeners>
        <listener class-name="com.amazon.utils.ExtentTestListener"/>
        <listener class-name="com.amazon.reporter.adapter.TestNGListener"/>
    </listeners>

    <!-- Chrome Latest on Windows 10 -->
    <test name="Chrome Latest - Windows 10">
        <parameter name="execution"        value="browserstack"/>
        <parameter name="browser"          value="chrome"/>
        <parameter name="browser_version"  value="latest"/>
        <parameter name="os"               value="Windows"/>
        <parameter name="os_version"       value="10"/>
        <classes>
            <class name="com.amazon.tests.HomePageTest"/>
            <class name="com.amazon.tests.SearchTest"/>
        </classes>
    </test>

    <!-- Firefox Latest on Windows 10 -->
    <test name="Firefox Latest - Windows 10">
        <parameter name="execution"        value="browserstack"/>
        <parameter name="browser"          value="firefox"/>
        <parameter name="browser_version"  value="latest"/>
        <parameter name="os"               value="Windows"/>
        <parameter name="os_version"       value="10"/>
        <classes>
            <class name="com.amazon.tests.HomePageTest"/>
            <class name="com.amazon.tests.SearchTest"/>
        </classes>
    </test>

    <!-- Edge Latest on Windows 11 -->
    <test name="Edge Latest - Windows 11">
        <parameter name="execution"        value="browserstack"/>
        <parameter name="browser"          value="edge"/>
        <parameter name="browser_version"  value="latest"/>
        <parameter name="os"               value="Windows"/>
        <parameter name="os_version"       value="11"/>
        <classes>
            <class name="com.amazon.tests.HomePageTest"/>
            <class name="com.amazon.tests.SearchTest"/>
        </classes>
    </test>

    <!-- Safari Latest on macOS Ventura -->
    <test name="Safari Latest - macOS Ventura">
        <parameter name="execution"        value="browserstack"/>
        <parameter name="browser"          value="safari"/>
        <parameter name="browser_version"  value="latest"/>
        <parameter name="os"               value="OS X"/>
        <parameter name="os_version"       value="Ventura"/>
        <classes>
            <class name="com.amazon.tests.HomePageTest"/>
            <class name="com.amazon.tests.SearchTest"/>
        </classes>
    </test>

</suite>
