<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Amazon.in Test Suite" verbose="1" parallel="tests" thread-count="4">

    <!-- Chrome Tests -->
    <test name="Chrome - Home Page Tests">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.amazon.tests.HomePageTest"/>
        </classes>
    </test>

    <test name="Chrome - Search Tests">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.amazon.tests.SearchTest"/>
        </classes>
    </test>

    <!-- Firefox Tests -->
    <test name="Firefox - Home Page Tests">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="com.amazon.tests.HomePageTest"/>
        </classes>
    </test>

    <test name="Firefox - Search Tests">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="com.amazon.tests.SearchTest"/>
        </classes>
    </test>

</suite>
